HOST=0.0.0.0
PORT=1337

# Public URL where Strapi is reachable (set in production, e.g. https://cms.example.com)
# PUBLIC_URL=http://localhost:1337

# Generate random strings for production
APP_KEYS=change-me-1,change-me-2
API_TOKEN_SALT=change-me-api-token-salt
ADMIN_JWT_SECRET=change-me-admin-jwt
TRANSFER_TOKEN_SALT=change-me-transfer-salt
JWT_SECRET=change-me-users-permissions-jwt

# Local dev: SQLite (default)
DATABASE_FILENAME=.tmp/data.db

# Production: PostgreSQL — data survives redeploys. Omit for local SQLite.
# Example (Neon / Supabase / Render): set URL + SSL for managed hosts.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
# DATABASE_SSL=true
