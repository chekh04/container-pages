{
  "name": "container-pages",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=web",
    "dev:web": "npm run dev --workspace=web",
    "dev:cms": "npm run develop --workspace=cms",
    "build": "npm run build --workspace=web && npm run build --workspace=cms",
    "build:web": "npm run build --workspace=web",
    "build:cms": "npm run build --workspace=cms",
    "start:web": "npm run start --workspace=web",
    "start:cms": "npm run start --workspace=cms"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
