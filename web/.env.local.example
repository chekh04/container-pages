# Запросы к Strapi выполняются на сервере Next — в Network вкладке браузера их не будет.
# В development в терминале Next печатаются [Strapi] → / ← (отключить: STRAPI_LOGGING=0).

# URL Strapi (серверный fetch из Next)
STRAPI_URL=http://localhost:1337

# Публичный URL Strapi (для next/image и абсолютных ссылок на медиа)
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# API Token (Settings → API Tokens в Strapi), только чтение
STRAPI_API_TOKEN=

# Секрет для POST /api/revalidate (должен совпадать с webhook / заголовком)
REVALIDATE_SECRET=change-me-in-production

# Канонический домен сайта (для metadataBase и canonical)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
