# Strapi is called from the Next server — you will not see those calls in the browser Network tab.
# In development the Next terminal logs [Strapi] → / ← (disable with STRAPI_LOGGING=0).

# Strapi URL (server-side fetch from Next)
STRAPI_URL=http://localhost:1337

# Public Strapi URL (for next/image and absolute media URLs)
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# API token (Strapi: Settings → API Tokens), read-only
STRAPI_API_TOKEN=

# Secret for POST /api/revalidate (must match webhook / header)
REVALIDATE_SECRET=change-me-in-production

# Canonical site URL (metadataBase and canonical)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
