# Runtime vars for the Next.js container (not baked into the bundle).
# Copy to web/.env and fill in values.

# Read-only API token — Strapi admin → Settings → API Tokens
STRAPI_API_TOKEN=

# Must match the header value for POST /api/revalidate
REVALIDATE_SECRET=change-me

# Suppress Strapi request logs in production
STRAPI_LOGGING=0
